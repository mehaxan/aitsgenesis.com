---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CTASection from '../components/CTASection.astro';
import Icon from '../components/Icon.astro';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  metaDescription: string;
  heroTitle: string;
  heroSubtitle: string;
  icon: string;
  features?: string[];
  technologies?: string[];
  breadcrumbs: BreadcrumbItem[];
  activeNav?: string;
  jsonLD?: object;
}

const {
  title,
  metaDescription,
  heroTitle,
  heroSubtitle,
  icon,
  features = [],
  technologies = [],
  breadcrumbs,
  activeNav,
  jsonLD,
} = Astro.props;
---
<BaseLayout
  title={title}
  description={metaDescription}
  activeNav={activeNav}
  jsonLD={jsonLD}
>
  <!-- Hero -->
  <section class="bg-white border-b border-slate-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-16 md:pb-20">
      <Breadcrumb items={breadcrumbs} />
      <div class="mt-10 max-w-3xl">
        <div class="inline-flex items-center justify-center w-14 h-14 bg-blue-600 text-white rounded-2xl mb-6 text-xl shadow-sm">
          <Icon name={icon} />
        </div>
        <h1 class="text-4xl md:text-[2.75rem] lg:text-5xl font-display font-bold text-slate-900 leading-[1.1] tracking-tight">
          {heroTitle}
        </h1>
        <p class="mt-5 text-lg md:text-xl text-slate-500 leading-relaxed max-w-2xl">
          {heroSubtitle}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/contact"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 text-white text-sm font-semibold rounded-xl hover:bg-blue-700 transition-colors"
          >
            Start a Project
            <i class="fa-solid fa-arrow-right text-xs"></i>
          </a>
          <a
            href="/contact"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-slate-100 text-slate-700 text-sm font-semibold rounded-xl hover:bg-slate-200 transition-colors"
          >
            Talk to an Expert
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Features band -->
  {features.length > 0 && (
    <section class="bg-slate-50 border-b border-slate-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <p class="text-[11px] font-bold uppercase tracking-widest text-slate-400 mb-6">
          What&apos;s covered
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-3">
          {features.map(f => (
            <div class="flex items-start gap-3">
              <span class="mt-0.5 flex-shrink-0 w-5 h-5 rounded-full bg-blue-100 inline-flex items-center justify-center">
                <i class="fa-solid fa-check text-blue-600" style="font-size:10px;"></i>
              </span>
              <span class="text-sm font-medium text-slate-700">{f}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Body: prose + sidebar -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 md:py-20">
    <div class="grid lg:grid-cols-[1fr_296px] gap-12 xl:gap-20 items-start">

      <!-- Prose content -->
      <div class="prose prose-slate prose-lg max-w-none
        prose-headings:font-display prose-headings:text-slate-900 prose-headings:tracking-tight
        prose-h2:text-[1.6rem] prose-h2:font-bold prose-h2:mt-12 prose-h2:mb-4 prose-h2:pb-3 prose-h2:border-b prose-h2:border-slate-100
        prose-h3:text-xl prose-h3:font-semibold prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-slate-600 prose-p:leading-relaxed
        prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline
        prose-strong:text-slate-800 prose-strong:font-semibold
        prose-ul:text-slate-600 prose-li:marker:text-blue-400
        prose-ol:text-slate-600
        first:prose-h2:mt-0">
        <slot />
      </div>

      <!-- Sidebar -->
      <aside class="lg:sticky lg:top-24 space-y-5">

        <!-- Technologies card -->
        {technologies.length > 0 && (
          <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-[11px] font-bold uppercase tracking-widest text-slate-400 mb-4">
              Technologies
            </p>
            <div class="flex flex-wrap gap-2">
              {technologies.map(t => (
                <span class="inline-block px-2.5 py-1 text-xs font-medium text-slate-600 bg-slate-50 border border-slate-200 rounded-lg">
                  {t}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- CTA card -->
        <div class="rounded-2xl bg-slate-900 text-white p-6">
          <div class="w-9 h-9 rounded-xl bg-blue-600 flex items-center justify-center mb-4 text-sm">
            <i class="fa-solid fa-comments"></i>
          </div>
          <h3 class="font-display font-bold text-base mb-1.5">
            Ready to get started?
          </h3>
          <p class="text-slate-400 text-sm leading-relaxed mb-5">
            Tell us about your project and we&apos;ll respond within one business day.
          </p>
          <a
            href="/contact"
            class="block w-full text-center py-2.5 bg-blue-600 text-white text-sm font-semibold rounded-xl hover:bg-blue-700 transition-colors"
          >
            Get in Touch
          </a>
        </div>

        <!-- Features recap (small, sidebar) -->
        {features.length > 0 && (
          <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-[11px] font-bold uppercase tracking-widest text-slate-400 mb-4">
              Capabilities
            </p>
            <ul class="space-y-2">
              {features.map(f => (
                <li class="flex items-start gap-2.5 text-sm text-slate-600">
                  <i class="fa-solid fa-circle-dot text-blue-400 mt-0.5 text-[10px] flex-shrink-0"></i>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        )}

      </aside>
    </div>
  </section>

  <CTASection />
</BaseLayout>
