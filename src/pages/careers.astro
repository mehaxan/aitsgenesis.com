---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Icon from '../components/Icon.astro';

const perks = [
  { icon: "arrow-trending-up", title: "Growth-Oriented Projects", desc: "Work on real AI products and enterprise software that reach thousands of users." },
  { icon: "academic-cap", title: "Learning & Development", desc: "Training budgets, conference allowances, and internal knowledge-sharing sessions." },
  { icon: "globe-alt", title: "Remote-Friendly Culture", desc: "Flexible working arrangements with async-first communication practices." },
  { icon: "bolt", title: "Ship Fast, Learn Faster", desc: "Short sprint cycles mean you see the impact of your work every few weeks." },
  { icon: "user-group", title: "Collaborative Environment", desc: "Flat hierarchy, open feedback culture, and engineers who love to pair and review." },
  { icon: "trophy", title: "Competitive Compensation", desc: "Market-rate salaries, performance bonuses, and equity participation for senior roles." },
];

const roles = [
  "Software Engineer (Full Stack)",
  "Frontend Engineer (React / Next.js)",
  "Backend Engineer (Node.js / Python)",
  "Mobile Engineer (React Native)",
  "ML / AI Engineer",
  "DevOps / Platform Engineer",
  "UX / Product Designer",
  "Product Manager",
  "Technical Sales & Partnerships",
];
---
<BaseLayout
  title="Careers at AITS Genesis"
  description="Build intelligent software and grow your career at AITS Genesis. We're hiring engineers, designers, and product managers passionate about AI and impactful technology."
>

  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-indigo-900 to-blue-800 py-24 md:py-32">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-white rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-64 h-64 bg-blue-300 rounded-full blur-3xl"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-blue-200 uppercase tracking-wider mb-3">Join Our Team</p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-bold text-white leading-tight max-w-3xl mx-auto">
        Build the Software the World Needs Next
      </h1>
      <p class="mt-6 text-xl text-blue-100 leading-relaxed max-w-2xl mx-auto">
        At AITS Genesis, you're not just writing code — you're building AI products used by hospitals, banks, schools, and farms. If you want your work to matter, this is where you belong.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="https://www.linkedin.com/company/aitsgenesis/jobs/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-4 bg-white text-indigo-700 font-bold rounded-xl hover:bg-blue-50 transition-colors shadow-lg text-sm"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
          See Open Positions on LinkedIn
        </a>
        <a href="/contact" class="inline-flex items-center gap-2 px-8 py-4 border border-white/30 text-white font-semibold rounded-xl hover:border-white/60 transition-colors text-sm">
          Send Us Your CV Directly
        </a>
      </div>
    </div>
  </section>

  <!-- Why AITS Genesis -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="Why AITS Genesis"
        title="Perks, Culture & What Sets Us Apart"
        subtitle="We've built a workplace where talented engineers can do the best work of their careers."
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {perks.map(p => (
          <div class="bg-slate-50 rounded-2xl border border-slate-200 p-6">
            <div class="text-blue-600">
              <Icon name={p.icon} class="w-7 h-7" />
            </div>
            <h3 class="mt-3 font-semibold text-slate-900">{p.title}</h3>
            <p class="mt-1 text-sm text-slate-600 leading-relaxed">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Open Roles -->
  <section class="py-20 md:py-28 bg-slate-50 border-y border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeader
        eyebrow="Open Roles"
        title="We're Hiring Across the Stack"
        subtitle="We hire for attitude and aptitude. Domain experience is a plus, not a requirement."
      />
      <div class="max-w-2xl mx-auto space-y-3">
        {roles.map(r => (
          <div class="flex items-center justify-between bg-white border border-slate-200 rounded-xl px-5 py-4">
            <span class="font-medium text-slate-800">{r}</span>
            <a
              href="https://www.linkedin.com/company/aitsgenesis/jobs/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-blue-600 font-semibold hover:text-blue-700 transition-colors flex items-center gap-1"
            >
              Apply
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <p class="text-slate-500 text-sm mb-4">Don't see a role that fits? We're always open to exceptional talent.</p>
        <a
          href="https://www.linkedin.com/company/aitsgenesis/jobs/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-7 py-3.5 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 transition-colors text-sm"
        >
          See All Open Positions
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Values alignment -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8 text-center">
        {[
          { value: "50+", label: "Team members globally", sub: "Specialists across engineering, design, product, and growth" },
          { value: "6", label: "Products in production", sub: "Real products you'll contribute to from day one" },
          { value: "18+", label: "Industry domains", sub: "Broad exposure that builds career-defining breadth" },
        ].map(s => (
          <div class="p-8 bg-slate-50 rounded-2xl border border-slate-200">
            <p class="text-5xl font-display font-bold text-blue-600">{s.value}</p>
            <p class="mt-2 text-lg font-semibold text-slate-900">{s.label}</p>
            <p class="mt-1 text-sm text-slate-500">{s.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Ready to Make an Impact?"
    subtitle="Apply through LinkedIn or reach out directly. We respond to every application."
    primaryLabel="See Open Positions"
    primaryHref="https://www.linkedin.com/company/aitsgenesis/jobs/"
    secondaryLabel="Contact Us"
    secondaryHref="/contact"
  />
</BaseLayout>
