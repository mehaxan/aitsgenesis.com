---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Message Sent — Thank You"
  description="Thank you for contacting AITS Genesis. We'll be in touch within one business day."
  noindex={true}
>
  <section class="min-h-[70vh] flex items-center justify-center bg-slate-50">
    <div class="max-w-lg mx-auto px-4 text-center py-20">
      <!-- Success icon -->
      <div class="w-20 h-20 mx-auto bg-emerald-100 rounded-full flex items-center justify-center mb-6">
        <svg class="w-10 h-10 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <h1 class="text-3xl font-display font-bold text-slate-900 mb-4">
        Your Message Has Been Sent!
      </h1>
      <p class="text-slate-600 leading-relaxed mb-8">
        Thank you for reaching out to AITS Genesis. A member of our team will review your message and get back to you within one business day.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-blue-600 text-white font-semibold rounded-xl hover:bg-blue-700 transition-colors text-sm">
          Back to Homepage
        </a>
        <a href="/products" class="inline-flex items-center gap-2 px-6 py-3 border border-slate-300 text-slate-700 font-semibold rounded-xl hover:border-blue-300 hover:text-blue-600 transition-colors text-sm">
          Explore Our Products
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
