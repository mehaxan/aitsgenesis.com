---
import { products, services, expertise, industries } from '../data/navigation';

interface Props {
  activeNav?: string;
}
const { activeNav } = Astro.props;
---
<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-200 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 flex-shrink-0" aria-label="AITS Genesis Home">
        <div class="w-8 h-8 bg-gradient-to-br from-blue-600 to-indigo-600 rounded-lg flex items-center justify-center">
          <span class="text-white font-display font-bold text-sm">AG</span>
        </div>
        <span class="font-display font-bold text-lg text-slate-900 hidden sm:block">AITS Genesis</span>
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden lg:flex items-center gap-0.5" aria-label="Main navigation">

        <!-- Products dropdown -->
        <div class="group relative">
          <button
            class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-slate-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all"
            aria-haspopup="true"
          >
            Products
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div class="absolute left-0 top-full pt-1 w-[500px] invisible group-hover:visible group-focus-within:visible opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 translate-y-1 group-hover:translate-y-0 group-focus-within:translate-y-0 transition-all duration-200 pointer-events-none group-hover:pointer-events-auto group-focus-within:pointer-events-auto">
            <div class="bg-white rounded-2xl shadow-xl border border-slate-200 p-4 grid grid-cols-2 gap-2">
              {products.map(p => (
                <a
                  href={p.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-start gap-3 p-3 rounded-xl hover:bg-slate-50 transition-colors group/item"
                >
                  <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style={{ backgroundColor: p.iconBg }}>
                    <span class="font-display font-bold text-xs" style={{ color: p.iconColor }}>{p.short}</span>
                  </div>
                  <div>
                    <p class="text-sm font-semibold text-slate-900 group-hover/item:text-blue-600 transition-colors">{p.name}</p>
                    <p class="text-xs text-slate-500 mt-0.5 leading-relaxed">{p.tagline}</p>
                  </div>
                </a>
              ))}
              <a href="/products" class="col-span-2 flex items-center justify-center gap-2 py-2.5 text-sm font-medium text-blue-600 hover:text-blue-700 border-t border-slate-100 mt-1 pt-3">
                View all products
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Services dropdown -->
        <div class="group relative">
          <button class={`flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-lg transition-all ${activeNav === 'services' ? 'text-blue-600 bg-blue-50' : 'text-slate-600 hover:text-blue-600 hover:bg-blue-50'}`} aria-haspopup="true">
            Services
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div class="absolute left-0 top-full pt-1 w-96 invisible group-hover:visible group-focus-within:visible opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 translate-y-1 group-hover:translate-y-0 group-focus-within:translate-y-0 transition-all duration-200 pointer-events-none group-hover:pointer-events-auto group-focus-within:pointer-events-auto">
            <div class="bg-white rounded-2xl shadow-xl border border-slate-200 p-4">
              <div class="grid grid-cols-2 gap-1">
                {services.map(s => (
                  <a href={`/services/${s.slug}`} class="px-3 py-2 text-sm text-slate-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">{s.name}</a>
                ))}
              </div>
              <a href="/services" class="flex items-center justify-center gap-2 py-2.5 text-sm font-medium text-blue-600 hover:text-blue-700 border-t border-slate-100 mt-2 pt-3">
                All services <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Expertise dropdown -->
        <div class="group relative">
          <button class={`flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-lg transition-all ${activeNav === 'expertise' ? 'text-blue-600 bg-blue-50' : 'text-slate-600 hover:text-blue-600 hover:bg-blue-50'}`}>
            Expertise
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div class="absolute left-0 top-full pt-1 w-72 invisible group-hover:visible group-focus-within:visible opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 translate-y-1 group-hover:translate-y-0 group-focus-within:translate-y-0 transition-all duration-200 pointer-events-none group-hover:pointer-events-auto group-focus-within:pointer-events-auto">
            <div class="bg-white rounded-2xl shadow-xl border border-slate-200 p-4">
              <div class="grid grid-cols-1 gap-1">
                {expertise.map(e => (
                  <a href={`/expertise/${e.slug}`} class="px-3 py-2 text-sm text-slate-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">{e.name}</a>
                ))}
              </div>
              <a href="/expertise" class="flex items-center justify-center gap-2 py-2.5 text-sm font-medium text-blue-600 hover:text-blue-700 border-t border-slate-100 mt-2 pt-3">
                All expertise <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Industries dropdown -->
        <div class="group relative">
          <button class={`flex items-center gap-1 px-3 py-2 text-sm font-medium rounded-lg transition-all ${activeNav === 'industries' ? 'text-blue-600 bg-blue-50' : 'text-slate-600 hover:text-blue-600 hover:bg-blue-50'}`}>
            Industries
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div class="absolute left-0 top-full pt-1 w-[480px] invisible group-hover:visible group-focus-within:visible opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 translate-y-1 group-hover:translate-y-0 group-focus-within:translate-y-0 transition-all duration-200 pointer-events-none group-hover:pointer-events-auto group-focus-within:pointer-events-auto">
            <div class="bg-white rounded-2xl shadow-xl border border-slate-200 p-4">
              <div class="grid grid-cols-3 gap-1">
                {industries.map(i => (
                  <a href={`/industries/${i.slug}`} class="px-3 py-2 text-sm text-slate-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors">{i.name}</a>
                ))}
              </div>
              <a href="/industries" class="flex items-center justify-center gap-2 py-2.5 text-sm font-medium text-blue-600 hover:text-blue-700 border-t border-slate-100 mt-2 pt-3">
                All industries <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
              </a>
            </div>
          </div>
        </div>

        <!-- Company dropdown -->
        <div class="group relative">
          <button class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-slate-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-all">
            Company
            <svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </button>
          <div class="absolute right-0 top-full pt-1 w-52 invisible group-hover:visible group-focus-within:visible opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 translate-y-1 group-hover:translate-y-0 group-focus-within:translate-y-0 transition-all duration-200 pointer-events-none group-hover:pointer-events-auto group-focus-within:pointer-events-auto">
            <div class="bg-white rounded-2xl shadow-xl border border-slate-200 p-2">
              <a href="/about" class="block px-3 py-2.5 text-sm text-slate-600 hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">About Us</a>
              <a href="/careers" class="block px-3 py-2.5 text-sm text-slate-600 hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">Careers</a>
              <a href="/custom-solutions" class="block px-3 py-2.5 text-sm text-slate-600 hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">Custom Solutions</a>
            </div>
          </div>
        </div>

        <a href="/contact" class="ml-3 px-5 py-2 bg-blue-600 text-white text-sm font-semibold rounded-xl hover:bg-blue-700 active:bg-blue-800 transition-colors shadow-sm shadow-blue-200">
          Get in Touch
        </a>
      </nav>

      <!-- Mobile hamburger button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-lg text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition-colors"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg id="menu-icon" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-nav" class="hidden lg:hidden border-t border-slate-200 bg-white max-h-[80vh] overflow-y-auto">
    <div class="max-w-7xl mx-auto px-4 py-4 space-y-2">
      <div>
        <p class="px-3 py-1.5 text-xs font-semibold text-slate-400 uppercase tracking-wider">Products</p>
        {products.map(p => (
          <a href={p.href} target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-slate-600 hover:text-blue-600 hover:bg-blue-50 transition-colors">
            <div class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0" style={{ backgroundColor: p.iconBg }}>
              <span class="font-display font-bold text-xs" style={{ color: p.iconColor }}>{p.short}</span>
            </div>
            {p.name}
          </a>
        ))}
        <a href="/products" class="block px-3 py-2 text-sm font-medium text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">→ All Products</a>
      </div>
      <div class="border-t border-slate-100 pt-2">
        <p class="px-3 py-1.5 text-xs font-semibold text-slate-400 uppercase tracking-wider">Services</p>
        <div class="grid grid-cols-2 gap-0.5">
          {services.map(s => (
            <a href={`/services/${s.slug}`} class="block px-3 py-2 text-sm text-slate-600 hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">{s.name}</a>
          ))}
        </div>
        <a href="/services" class="block px-3 py-2 text-sm font-medium text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">→ All Services</a>
      </div>
      <div class="border-t border-slate-100 pt-2">
        <p class="px-3 py-1.5 text-xs font-semibold text-slate-400 uppercase tracking-wider">Expertise</p>
        <div class="grid grid-cols-2 gap-0.5">
          {expertise.map(e => (
            <a href={`/expertise/${e.slug}`} class="block px-3 py-2 text-sm text-slate-600 hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">{e.name}</a>
          ))}
        </div>
        <a href="/expertise" class="block px-3 py-2 text-sm font-medium text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">→ All Expertise</a>
      </div>
      <div class="border-t border-slate-100 pt-2">
        <p class="px-3 py-1.5 text-xs font-semibold text-slate-400 uppercase tracking-wider">Industries</p>
        <div class="grid grid-cols-2 gap-0.5">
          {industries.map(i => (
            <a href={`/industries/${i.slug}`} class="block px-3 py-2 text-sm text-slate-600 hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">{i.name}</a>
          ))}
        </div>
        <a href="/industries" class="block px-3 py-2 text-sm font-medium text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">→ All Industries</a>
      </div>
      <div class="border-t border-slate-100 pt-2">
        <p class="px-3 py-1.5 text-xs font-semibold text-slate-400 uppercase tracking-wider">Company</p>
        <a href="/about" class="block px-3 py-2 text-sm text-slate-600 hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">About Us</a>
        <a href="/careers" class="block px-3 py-2 text-sm text-slate-600 hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">Careers</a>
        <a href="/custom-solutions" class="block px-3 py-2 text-sm text-slate-600 hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-colors">Custom Solutions</a>
      </div>
      <div class="border-t border-slate-100 pt-3 pb-2">
        <a href="/contact" class="block w-full text-center px-5 py-3 bg-blue-600 text-white text-sm font-semibold rounded-xl hover:bg-blue-700 transition-colors">
          Get in Touch
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const nav = document.getElementById('mobile-nav');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !nav?.classList.contains('hidden');
    nav?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
    menuIcon?.classList.toggle('hidden', !isOpen);
    closeIcon?.classList.toggle('hidden', isOpen);
  });
</script>
