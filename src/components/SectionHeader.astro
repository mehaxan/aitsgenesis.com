---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  centered?: boolean;
}
const { eyebrow, title, subtitle, centered = true } = Astro.props;
---
<div class={`mb-12 md:mb-16 ${centered ? 'text-center max-w-3xl mx-auto' : ''}`}>
  {eyebrow && (
    <p class="inline-flex items-center gap-2 text-sm font-semibold text-blue-600 uppercase tracking-wider mb-3">
      <span class="w-6 h-px bg-blue-600"></span>
      {eyebrow}
      <span class="w-6 h-px bg-blue-600"></span>
    </p>
  )}
  <h2 class="text-3xl md:text-4xl font-display font-bold text-slate-900 leading-tight">
    {title}
  </h2>
  {subtitle && (
    <p class="mt-4 text-lg text-slate-600 leading-relaxed">
      {subtitle}
    </p>
  )}
</div>
